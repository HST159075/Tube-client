# ─── Better Auth (backend root URL) ──────────────────────────────────────────
# Better Auth client নিজেই /api/auth/* append করে
# তোমার backend: app.all("/api/auth/*all", toNodeHandler(auth))
NEXT_PUBLIC_BACKEND_URL=


# ─── Custom API routes (/api/v1/...) ──────────────────────────────────────────
# তোমার backend: app.use("/api/v1/media", mediaRoutes) ইত্যাদি
NEXT_PUBLIC_API_URL=https://tube-server.onrender.com/api/v1

# ─── Production ───────────────────────────────────────────────────────────────
# NEXT_PUBLIC_BACKEND_URL=https://your-backend.render.com
# NEXT_PUBLIC_API_URL=https://your-backend.render.com/api/v1
